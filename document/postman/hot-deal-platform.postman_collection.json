{
  "info": {
    "name": "Hot Deal Platform",
    "_postman_id": "4e0ce44a-87f6-45f3-92de-f11e2f9ed620",
    "description": "Core health, documentation, and admin starter endpoints for Hot Deal Platform.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Platform",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            }
          }
        },
        {
          "name": "Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/info",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "info"
              ]
            }
          }
        },
        {
          "name": "OpenAPI Docs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api-docs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api-docs"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin (Starter)",
      "item": [
        {
          "name": "Ingestion Status (Planned Endpoint)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{adminUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/ingestion/jobs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "ingestion",
                "jobs"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "adminUsername",
      "value": "admin"
    },
    {
      "key": "adminPassword",
      "value": "admin123"
    }
  ]
}
